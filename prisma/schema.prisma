datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  role         String   @default("user")
  avatarUrl    String?
  loginCount   Int      @default(0)
  totalUsageTime Int    @default(0) // in minuti
  theme        String   @default("dark")
  
  // Relazioni
  cards          Card[]          @relation("CardAssignees")
  lists          List[]          @relation("ListAssignees")
  comments       Comment[]
  projectComments ProjectComment[]
  checklistItems ChecklistItem[] @relation("ChecklistItemAssignees")
  notifications  Notification[]
  pendingNotifications PendingNotification[]
  clients        Client[]        @relation("ClientCollaborators")
  
  // Impostazioni Notifiche
  notifyMentions       Boolean @default(true)
  notifyAssignedCard   Boolean @default(true)
  notifyAssignedList   Boolean @default(true)
  notifyCardDue        Boolean @default(true)
  notifyDailyRecap     Boolean @default(true)

  // Impostazioni AI
  aiChecklistEnabled   Boolean @default(true)
  aiReportEnabled      Boolean @default(true)
  aiCategorizeEnabled  Boolean @default(true)
}

model Board {
  id        String   @id @default(cuid())
  name      String
  
  lists     List[]
  cards     Card[]
  labels    Label[]

  isArchived Boolean @default(false)
}

model List {
  id        String    @id @default(cuid())
  name      String
  order     Float     @default(0)
  
  startDate DateTime?
  endDate   DateTime?
  
  boardId   String
  board     Board     @relation(fields: [boardId], references: [id])
  
  cards     Card[]
  
  // Custom feature: Assegnare intere liste agli utenti (impossibile su Trello standard)
  assignees User[]    @relation("ListAssignees")

  isArchived Boolean @default(false)
}

model Card {
  id          String    @id @default(cuid())
  name        String
  description String?
  due         DateTime?
  order       Float     @default(0)
  listId      String
  list        List      @relation(fields: [listId], references: [id], onDelete: Cascade)
  boardId     String
  board       Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  color       String?  // New field for whole card color
  
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  clientId    String?
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  checklists  Checklist[]
  comments    Comment[]
  assignees   User[]    @relation("CardAssignees")
  labels      Label[]   @relation("CardLabels")
  attachments Attachment[]

  updatedAt   DateTime @default(now()) @updatedAt
  completedAt DateTime? // Traccia storicamente quando è stata completata
  isArchived Boolean @default(false)
}

model Label {
  id        String   @id @default(cuid())
  name      String
  color     String
  
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id])
  
  cards     Card[]   @relation("CardLabels")
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
  
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
}

model Checklist {
  id        String   @id @default(cuid())
  title     String
  order     Float    @default(0)
  
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  
  items     ChecklistItem[]
}

model ChecklistItem {
  id          String    @id @default(cuid())
  text        String
  isCompleted Boolean   @default(false)
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  order       Float     @default(0)
  
  parentId    String?
  parent      ChecklistItem?   @relation("SubItems", fields: [parentId], references: [id], onDelete: Cascade)
  subItems    ChecklistItem[]  @relation("SubItems")

  // Assignees per singolo item (Opzionale, ma Trello lo fa coi membri Advanced)
  assignees   User[]    @relation("ChecklistItemAssignees")
  dueDate     DateTime?
  notes       String?   // Aggiunto per le note espandibili
  completedAt DateTime? // Traccia storicamente quando è stato completato
}

model Client {
  id          String   @id @default(cuid())
  name        String
  createdAt   DateTime @default(now())
  
  driveFolderId String? // Google Drive folder ID
  notebookLmUrl String? // Link to Google NotebookLM
  notes         String? @db.Text // Quick notes / Contact info
  sheetData     String? @db.Text // Parsed Google Sheet JSON
  color         String? // Hex color code for the client row
  
  projects    Project[]
  cards       Card[]
  collaborators User[]  @relation("ClientCollaborators")
}


model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  clientName  String?  // Kept for backwards compatibility
  
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())
  
  // KPI e Nuovi Campi
  status      String   @default("In Coda") // Preventivo, In Coda, In Corso, Completato, In Pausa
  category    String?  // Sviluppo Web, SEO, Social, ecc.
  priority    String   @default("Normale") // Bassa, Normale, Alta
  dueDate     DateTime?
  estimatedHours Float?
  actualHours    Float?
  sellingPrice   Float?
  budget         Float?
  effort         Float?
  driveFolderId  String?
  notes          String?
  
  cards       Card[]
  comments    ProjectComment[]
  attachments Attachment[]

  isArchived Boolean @default(false)
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  read      Boolean  @default(false)
  link      String?  
  createdAt DateTime @default(now())
}

model ProjectComment {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
  
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
}

model Attachment {
  id        String   @id @default(cuid())
  name      String
  url       String
  
  cardId    String?
  card      Card?    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

model PendingNotification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "MENTION", "ASSIGN", "COMMENT", "CARD_ADD", "BOARD_UPDATE"
  message   String
  link      String?
  createdAt DateTime @default(now())
}
